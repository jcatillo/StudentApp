    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.6",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.21.0",
